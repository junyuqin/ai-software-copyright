# 慧学通项目 .gitignore
# 禁止提交敏感配置与构建产物

# ==================== 环境变量 ====================
.env
.env.local
.env.*.local

# ==================== Python ====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ==================== IDE ====================
.idea/
.vscode/
*.swp
*.swo
*~

# ==================== 测试与日志 ====================
.pytest_cache/
.coverage
htmlcov/
*.log
logs/

# ==================== Docker ====================
.docker/

# ==================== 前端构建产物 ====================
src/frontend/dist/
src/frontend/node_modules/

# ==================== 数据库 ====================
*.db
*.sqlite3

# ==================== 系统文件 ====================
.DS_Store
Thumbs.db
